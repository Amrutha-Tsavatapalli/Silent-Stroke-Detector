# Server Configuration
PORT=8080
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/silent_stroke_detector

# Authentication Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-in-production

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Alert Configuration
ALERT_THRESHOLD=0.70

# CORS Configuration
# Comma-separated list of allowed origins
# Use "*" to allow all origins (development only)
# Production example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging Configuration
LOG_LEVEL=info
